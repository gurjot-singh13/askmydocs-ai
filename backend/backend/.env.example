# Copy this file to .env and fill in real values

# PostgreSQL — async driver
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/askmydocs

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-char-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google AI (needed for Phase 2+)
GOOGLE_API_KEY=your-google-api-key-here

# Qdrant (needed for Phase 2+)
QDRANT_URL=http://localhost:6333

# File storage (needed for Phase 2+)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
